{
  "framework": null,
  "rewrites": [
    { "source": "/install.txt", "destination": "/install.txt" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
